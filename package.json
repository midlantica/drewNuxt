{
  "name": "nuxt-app",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev",
    "generate": "nuxt generate && npm run clean:output",
    "clean:output": "find .output/public -type f \\( -name '*.afdesign' -o -name '*.af' -o -name '*.psd' -o -name '*.ai' -o -name '*.fig' -o -name '*.sketch' \\) -delete",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "@nuxt/devtools": "^1.7.0",
    "@nuxt/eslint": "^1.15.2",
    "@tailwindcss/postcss": "^4.2.2",
    "@tailwindcss/vite": "^4.2.2",
    "eslint": "^9.15.0",
    "nuxt": "^4.4.2",
    "nuxt-gtag": "^4.1.0",
    "postcss": "^8.5.9",
    "prettier": "^3.8.2",
    "tailwindcss": "^4.2.2",
    "vue": "^3.5.31",
    "vue-router": "^4.5.0"
  },
  "dependencies": {
    "@nuxtjs/google-fonts": "^3.2.0",
    "@pinia/nuxt": "^0.11.3",
    "@vueuse/core": "^14.2.1",
    "@vueuse/nuxt": "^14.2.1",
    "pinia": "^3.0.4",
    "vueperslides": "^3.5.1"
  }
}
